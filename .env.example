# PostgreSQL
POSTGRES_DB=jira_analytics
POSTGRES_USER=admin
POSTGRES_PASSWORD=secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# Backend / host CLIs default to host port 5433.
# Inside Docker, docker-compose.yml overrides this to point at the `db` service on the compose network.
DATABASE_URL=postgresql://admin:secret@localhost:5433/jira_analytics

# Jira
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your_token

# Optional: scope sync to a single project (e.g. ENG). Leave empty for all projects.
JIRA_PROJECT_KEY=

# Optional: override custom-field IDs (defaults shown). Find IDs at /rest/api/3/field.
# JIRA_FIELD_SPRINT=customfield_10020
# JIRA_FIELD_STORY_POINTS=customfield_10016
# JIRA_FIELD_TEAM=customfield_10001
# JIRA_FIELD_REPORTED_BY_CUSTOMER=customfield_10100
# JIRA_FIELD_CUSTOMER=customfield_10101
# JIRA_FIELD_PROD_RELEASE_DATE=customfield_10102
# JIRA_FIELD_EPIC_LINK=customfield_10014

# AI scoring CLI (backend/cli/score.py) shells out to the `claude` CLI; no API
# key is needed — your Claude Code session handles auth. Override the default
# model and per-issue timeout here if needed.
# CLAUDE_MODEL=claude-sonnet-4-6
# SCORING_TIMEOUT_SECS=600
